{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=analytic-ai;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtTokenOptions": {
    "SecretKey": "somesecretkeymustbeMoReSecReT!",
    "ExpiresMinutes": 15
  },
  "RefreshTokenOptions": {
    "ExpiresDays": 90
  },
  "Identity": {
    "Password": {
      "RequireDigit": true,
      "RequiredLength": 6,
      "RequireNonAlphanumeric": false,
      "RequireUppercase": false,
      "RequireLowercase": false
    },
    "Lockout": {
      "MaxFailedAccessAttempts": 3,
      "DefaultLockoutMinutes": 15,
      "AllowedForNewUsers": true
    },
    "User": {
      "RequireUniqueEmail": false,
      "AllowedUserNameCharacters": 50
    },
    "SignIn": {
      "RequireConfirmedAccount": false,
      "RequireConfirmedEmail": false,
      "RequireConfirmedPhoneNumber": false
    },
    "Token": {
      "EmailConfirmationTokenProvider": "Email",
      "PasswordResetTokenProvider": "Email",
      "TokenLifespanHours": 24
    }
  },
  "AllowedHosts": "*"
}
